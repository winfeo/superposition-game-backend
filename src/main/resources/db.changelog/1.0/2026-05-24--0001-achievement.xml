<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="table.achievement" value="achievement"/>

    <!-- Словарь всех существующих достижений -->
    <changeSet id="2026-05-24--0001-achievement" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="${table.achievement}"/>
            </not>
        </preConditions>

        <createTable tableName="${table.achievement}">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="icon_url" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>