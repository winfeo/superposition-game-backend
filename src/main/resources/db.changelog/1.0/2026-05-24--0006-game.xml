<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="table.game" value="game"/>
    <property name="table.user" value="user"/>
    <property name="idx.game_winner" value="idx_game_winner"/>
    <property name="idx.game_date" value="idx_game_date"/>

    <!-- Таблица всех сыгранных игр -->
    <changeSet id="2026-05-24--0006-game" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="${table.game}"/>
            </not>
        </preConditions>

        <createTable tableName="${table.game}">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="winner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_game_winner"
                             referencedTableName="${table.user}"
                             referencedColumnNames="id"/>
            </column>
            <column name="total_moves" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="played_at" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Индекс для получения статистики (количества) побед игрока -->
    <changeSet id="2026-05-24--0006-game-winner-idx" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists tableName="${table.game}" indexName="${idx.game_winner}"/>
            </not>
        </preConditions>
        <createIndex tableName="${table.game}" indexName="${idx.game_winner}">
            <column name="winner_id"/>
        </createIndex>
    </changeSet>

    <!-- Индекс для сортировки игр по дате -->
    <changeSet id="2026-05-24--0006-game-date-idx" author="winfeo">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists tableName="${table.game}" indexName="${idx.game_date}"/>
            </not>
        </preConditions>
        <createIndex tableName="${table.game}" indexName="${idx.game_date}">
            <column name="played_at"/>
        </createIndex>
    </changeSet>
    
</databaseChangeLog>